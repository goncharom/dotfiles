#!/bin/bash
# ABOUTME: Task graph executor that loops through JSONL tasks with eval-based verification.
# ABOUTME: Supports dependency tracking, multiple grader types, and skill-based evaluation.

TASKS_FILE="tasks.jsonl"
PROGRESS_FILE="progress.txt"

if [ "$1" = "-i" ]; then
    if [ ! -f "$PROGRESS_FILE" ]; then
        touch "$PROGRESS_FILE"
        echo "Created $PROGRESS_FILE"
    else
        echo "$PROGRESS_FILE already exists"
    fi
    if [ ! -f "$TASKS_FILE" ]; then
        cat > "$TASKS_FILE" << 'JSONL'
{
  "id": "1",
  "desc": "Example task: Replace this with your first real task.",
  "deps": [],
  "status": "pending",
  "evals": [
    {"type": "tests_pass", "paths": ["tests/test_example.py"]}
  ],
}
{
  "id": "2",
  "desc": "Example task: This depends on task 1. Replace with your second task.",
  "deps": ["1"],
  "status": "pending",
  "evals": [
    {"type": "build_succeeds"},
    {"type": "cmd", "run": "echo 'custom check passed'"}
  ],
}
JSONL
        echo "Created $TASKS_FILE with 2 example tasks"
    else
        echo "$TASKS_FILE already exists"
    fi
    exit 0
fi

MAX_TASKS=${1:-5}

read -r -d '' PROMPT << 'EOF'
You are executing tasks from a task graph with built-in evaluation gates.

STARTUP:
1. Run: pwd
2. Run: git log --oneline -5
3. Review the tasks file and progress file provided above
4. Find the next task with status "pending" whose deps are all "done" that YOU think has the highest priority

RULES:
- Work on exactly ONE task this session
- Update task status in tasks.jsonl: "pending" → "done" (or "blocked" if stuck)
- Append to progress.txt: timestamp, task ID, what you did, outputs, learnings
- You MAY create new tasks by appending to tasks.jsonl (use multi-line JSON format)
- Complete ONE task only, then say "TASK COMPLETE" and stop

JSONL FORMAT:
The tasks.jsonl file uses multi-line JSON objects separated by blank lines. Each task object:
{
  "id": "X",
  "desc": "Detailed task description",
  "deps": ["Y", "Z"],
  "status": "pending",
  "evals": [...],
}

EVALS - Verification Gates (must ALL pass before marking done):
The "evals" array defines automated checks. Run each one before marking task "done":

| Type | Fields | What it does |
|------|--------|--------------|
| tests_pass | paths: ["test/foo.py"] | Run pytest on specified paths, must pass |
| build_succeeds | (none) | Run the project's build command, must succeed |
| file_exists | path: "src/foo.py" | Verify the file exists |
| file_contains | path: "src/foo.py", pattern: "class Foo" | Grep for pattern in file |
| grep_present | pattern: "TODO", paths: ["src/*.py"] | Pattern MUST be found |
| grep_absent | pattern: "TODO", paths: ["src/*.py"] | Pattern must NOT be found |
| cmd | run: "any shell command" | Command must exit 0 |
| llm_rubric | criteria: ["No secrets", "Has tests"] | You judge against criteria |
| skill | name: "security-audit", blocking: true | Invoke skill, check for EVAL_RESULT: PASS |
| human_approval | prompt: "Review the API" | Auto-mark as "blocked", needs human |

If ANY eval fails:
- Do NOT mark task as "done"
- Mark as "blocked" with reason in progress.txt
- Explain which eval failed and why


VERIFICATION CHECKLIST (before marking done):
1. All evals in the "evals" array pass
3. Then mark "done"

PROGRESS.TXT FORMAT:
After completing work, append:
---
## [task-id] Task description
Completed: <timestamp>

### What I did
<description of work>

### Output/Results
<actual outputs, findings, deliverables>

### Evals Run
<list each eval and pass/fail status>

### Learnings
<insights, notes for future tasks>

### New tasks created
<list any tasks added to graph, or "none">

After ONE task, stop.
EOF



count=0
while [ $count -lt $MAX_TASKS ]; do
    echo "=== Task $((count + 1)) of $MAX_TASKS ==="

    if ! grep -q '"status":"pending"\|"status": "pending"' "$TASKS_FILE" 2>/dev/null; then
        echo "No pending tasks remaining."
        break
    fi

    result=$(opencode run "Read $TASKS_FILE, then $PROGRESS_FILE. $PROMPT")

    echo "$result"

    ((count++))

    echo ""
    echo "=== Task $((count)) complete ==="
    echo ""
done

echo "Done. Completed $count task(s)."
